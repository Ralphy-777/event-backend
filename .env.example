# Django
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=your-backend.onrender.com,localhost,127.0.0.1
BACKEND_URL=https://your-backend.onrender.com

# Database
DB_NAME=eventpro
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# Email bridge
# Render backend sends verification, forgot-password, and guest-invitation
# emails through the deployed Next.js route on Vercel.
EMAIL_HOST_USER=mailer-account@example.com
# If EMAIL_BRIDGE_URL is not set, the backend falls back to FRONTEND_URL.
EMAIL_BRIDGE_URL=https://your-frontend.vercel.app
EMAIL_BRIDGE_SECRET=replace-with-a-long-random-shared-secret

# PayMongo
PAYMONGO_SECRET_KEY=sk_live_your_key
PAYMONGO_PUBLIC_KEY=pk_live_your_key
PAYMONGO_BASE_URL=https://api.paymongo.com/v1

# GCash Manual
GCASH_RECEIVER_NUMBER=
GCASH_RECEIVER_NAME=

# Frontend URL
FRONTEND_URL=https://eventpro-frontend-eight.vercel.app

# CORS
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://eventpro-frontend-eight.vercel.app,http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=https://eventpro-frontend-eight.vercel.app,https://your-backend.onrender.com,http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000
